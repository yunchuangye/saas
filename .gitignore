.env
.env.local
.env.production
.env.development
.env.production.local
.env.development.local

# Logs
*.log
npm-debug.log*
pnpm-debug.log*
logs/*.log

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp

# Drizzle migrations (keep schema, ignore generated SQL if needed)
