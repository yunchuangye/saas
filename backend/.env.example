# ============================================================
# gujia.app 后端配置文件
# 修改此文件后需重启后端服务才能生效
# ============================================================

# ------------------------------------------------------------
# 【必填】域名与公网地址配置
# ------------------------------------------------------------
# 前端访问域名（用于 CORS 白名单，多个域名用英文逗号分隔）
# 示例：FRONTEND_URL=https://gujia.app,https://www.gujia.app
FRONTEND_URL=https://gujia.app

# 后端 API 公网地址（前端调用后端接口时使用的地址）
# 示例1（独立域名）：BACKEND_PUBLIC_URL=https://api.gujia.app
# 示例2（同域反代）：BACKEND_PUBLIC_URL=https://gujia.app
BACKEND_PUBLIC_URL=https://api.gujia.app

# ------------------------------------------------------------
# 【必填】服务端口
# ------------------------------------------------------------
PORT=8721
FRONTEND_PORT=8720

# ------------------------------------------------------------
# 【必填】数据库配置（MySQL）
# ------------------------------------------------------------
DB_HOST=localhost
DB_PORT=3306
DB_USER=gujia
DB_PASSWORD=your_db_password
DB_NAME=gujia

# ------------------------------------------------------------
# 【必填】Redis 配置
# ------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=your_redis_password

# ------------------------------------------------------------
# 【必填】JWT 鉴权密钥（生产环境务必修改为随机长字符串）
# ------------------------------------------------------------
JWT_SECRET=your_random_jwt_secret_here
JWT_EXPIRES_IN=7d

# ------------------------------------------------------------
# 【可选】CORS 跨域白名单（高级配置）
# 留空则自动使用 FRONTEND_URL；填写后会覆盖 FRONTEND_URL 的 CORS 设置
# 多个域名用英文逗号分隔，* 表示允许所有来源（仅开发环境使用）
# ------------------------------------------------------------
# CORS_ORIGINS=https://gujia.app,https://www.gujia.app,http://localhost:8720
# 本地开发示例: CORS_ORIGINS=http://localhost:8720

# ------------------------------------------------------------
# 【可选】采集微服务配置（scrapling-service，用于 OpenClaw 采集引擎）
# 如果启动了 scrapling-service，请取消注释并填写地址
# ------------------------------------------------------------
# SCRAPLING_SERVICE_URL=http://localhost:8722

# ------------------------------------------------------------
# 【可选】OpenAI / LLM 配置（用于 AI 自动估值分析功能）
# ------------------------------------------------------------
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# ------------------------------------------------------------
# 【可选】S3 / 对象存储配置（用于报告文件上传）
# ------------------------------------------------------------
# S3_BUCKET=gujia-files
# S3_REGION=ap-northeast-1
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key

# ------------------------------------------------------------
# 【可选】短信服务配置（用于手机号验证码登录）
# ------------------------------------------------------------
# SMS_PROVIDER=aliyun
# SMS_ACCESS_KEY=your_access_key
# SMS_SECRET_KEY=your_secret_key
# SMS_SIGN_NAME=估价平台
# SMS_TEMPLATE_CODE=SMS_xxxxxxxxx

# ------------------------------------------------------------
# 运行环境（development | production）
# ------------------------------------------------------------
NODE_ENV=development
